{% extends "base.jinja" %}
{% from "includes/moderator_macros.html" import edit_event_container with context %}

{% block head %}
<title>Mozilla Moderator - Events archive</title>
{% endblock %}

{% block content %}

<h3 class="text-center">Events Archive</h3>

{% for event in events %}
<div class="card mb-4">
  <div class="card-body">
    <a href="{{ url('event', e_slug=event.slug) }}" class="event-listing">
      <h1>{{ event.name }}</h1>
      <span class="questions-counter"> {{ event.approved_count }} questions asked</span>
    </a>
  </div>
  {{ edit_event_container(event, request.user) }}
</div>
{% endfor %}

{% if events %}
{% set num_pages = events.paginator.num_pages %}
{% set current = events.number %}
{% set window = 2 %}
{% set window_start = [current - window, 2] | max %}
{% set window_end = [current + window, num_pages - 1] | min %}
<nav aria-label="Page navigation">
  <ul class="pagination pagination-sm justify-content-center">
    <li class="page-item {% if not events.has_previous() %}disabled{% endif %}">
      <a class="page-link" href="{% if events.has_previous() %}?page={{ events.previous_page_number() }}{% else %}#{% endif %}" aria-label="Previous">
        <span aria-hidden="true">&laquo;</span>
      </a>
    </li>

    {# Always show page 1 #}
    <li class="page-item {% if current == 1 %}active{% endif %}">
      <a class="page-link" href="?page=1">1</a>
    </li>

    {# Leading ellipsis if window starts past page 2 #}
    {% if window_start > 2 %}
    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
    {% endif %}

    {# Windowed range (excluding 1 and num_pages, those are rendered separately) #}
    {% for i in range(window_start, window_end + 1) %}
    <li class="page-item {% if i == current %}active{% endif %}">
      <a class="page-link" href="?page={{ i }}">{{ i }}</a>
    </li>
    {% endfor %}

    {# Trailing ellipsis if window ends before num_pages - 1 #}
    {% if window_end < num_pages - 1 %}
    <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
    {% endif %}

    {# Always show last page if it differs from page 1 #}
    {% if num_pages > 1 %}
    <li class="page-item {% if current == num_pages %}active{% endif %}">
      <a class="page-link" href="?page={{ num_pages }}">{{ num_pages }}</a>
    </li>
    {% endif %}

    <li class="page-item {% if not events.has_next() %}disabled{% endif %}">
      <a class="page-link" href="{% if events.has_next() %}?page={{ events.next_page_number() }}{% else %}#{% endif %}" aria-label="Next">
        <span aria-hidden="true">&raquo;</span>
      </a>
    </li>
  </ul>
</nav>
{% endif %}
{% endblock %}