{% extends "base.jinja" %}
{% from "includes/moderator_macros.html" import user_profile %}
{% from "includes/form_macros.html" import floating, check, field_errors %}

{% block head %}
<title>Mozilla Moderator - {{ event.name }}</title>
{% endblock %}

{% block breadcrumb %}
{% if q_form.errors %}
<div class="alert alert-danger alert-dismissible" role="alert">
  Please correct the errors below.
  <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
</div>
{% endif %}
{% endblock %}

{% block content %}
<header class="event-header">
  <h1 class="event-title">{{ event.name }}</h1>
  <div class="event-meta">
    {% if event.event_date %}
    <time class="event-meta-date" datetime="{{ event.event_date }}">
      <i class="bi bi-calendar3" aria-hidden="true"></i>
      {{ event.event_date|date('F j, Y') }}
    </time>
    {% endif %}
    {% if event.is_nda %}<span class="badge bg-warning-subtle text-warning-emphasis">NDA</span>{% endif %}
    {% if event.is_moderated %}<span class="badge bg-info-subtle text-info-emphasis">Moderated</span>{% endif %}
    {% if event.archived %}<span class="badge bg-secondary-subtle text-secondary-emphasis">Archived</span>{% endif %}
  </div>
  {% if event.body %}
  <div class="event-body">{{ event.body|to_markdown }}</div>
  {% endif %}
</header>

{% if open %}
<div class="composer mb-4">
  <div class="composer-header">
    <h2 class="composer-title">Ask your question</h2>
    <div class="composer-meta">
      {% if event.is_moderated and not event.archived %}
      <span class="composer-note">
        <i class="bi bi-shield-check" aria-hidden="true"></i>
        Moderated — questions need approval
      </span>
      {% endif %}
      <a class="composer-link" href="https://guides.github.com/features/mastering-markdown/" target="_blank">
        <i class="bi bi-markdown" aria-hidden="true"></i>
        Markdown supported
      </a>
    </div>
  </div>
  <form method="post" action="{{ url('event', e_slug=event.slug) }}" id="question-form">
    {% csrf_token %}
    {{ q_form.non_field_errors() }}
    <div class="composer-body">
      <div class="selfimage">
        {% if not user.userprofile.avatar_url %}
        <img alt="Unknown profile image" src="{{ static('img/unknown.png') }}" />
        {% else %}
        <img src="{{ user.userprofile.avatar_url }}" alt="User profile image" />
        {% endif %}
      </div>
      <div class="composer-input">
        {{ q_form.question }}
        {{ field_errors(q_form.question) }}
      </div>
    </div>
    {% if event.is_moderated %}
    <div class="contact-info-container composer-aux">
      {{ floating(q_form.submitter_contact_info, "Contact email (optional)") }}
    </div>
    {% endif %}
    <div class="composer-footer">
      <div class="form-check m-0">
        {{ q_form.is_anonymous }}
        <label class="form-check-label" for="{{ q_form.is_anonymous.id_for_label }}">
          Post as anonymous
        </label>
      </div>
      <input type="submit" class="btn btn-primary" value="Post question">
    </div>
  </form>
</div>
{% endif %}

{% for q in questions %}
<div class="card mb-3">
  <div class="card-body">
    {% if q.addressed %}
    <div class="ribbon-wrapper">
      <div class="ribbon">answered</div>
    </div>
    {% endif %}

    {{ user_profile(q.asked_by, q.is_anonymous) }}

    <div class="question-text">
      <h3>{{ q.question|to_markdown }}</h3>
    </div>

    <div class="vote-container">
      {% if event.users_can_vote %}
      {% if not open or user.userprofile.is_admin or event.created_by == user %}
      <span class="vote-count">{{ q.vote_count }}</span>
      {% endif %}
      {% if open %}
      {% if user_voted(q, user) %}
      <button class="btn btn-dark btn-sm vote" id="{{ q.id }}">
        <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i>
        Remove the upvote
      </button>
      {% else %}
      <button class="btn btn-light btn-sm vote" id="{{ q.id }}">
        <i class="bi bi-hand-thumbs-up" aria-hidden="true"></i>
        Upvote
      </button>
      {% endif %}
      {% endif %}
      {% endif %}
      {% if open and can_answer_question(q, user) %}
      <button class="btn btn-secondary btn-sm reply-button" id="{{ q.id }}" title="Answer this question"
        data-bs-toggle="modal" data-bs-target="#AnswerModal">
        reply
      </button>
      {% endif %}
    </div>

    {% if q.answer %}
    <div class="reply-row">
      {{ q.answer|to_markdown }}
    </div>
    {% endif %}
    {% if q_form.instance.id == q.id %}
    {{ q_form.answer.errors }}
    {% endif %}

  </div>
</div>
{% endfor %}

<!-- Modal for Question Reply -->
<div class="modal fade" tabindex="-1" role="dialog" aria-labelledby="AnswerModalLabel" id="AnswerModal">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <form method="post" action="" id="answer-form">
        {% csrf_token %}
        <div class="modal-header">
          <h4 class="modal-title">Answer</h4>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          {{ floating(q_form.answer, "Your reply",
                      help='<a href="https://guides.github.com/features/mastering-markdown/" target="_blank">Markdown supported.</a>') }}
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          <input type="submit" class="btn btn-primary" value="Submit">
        </div>
      </form>
    </div>
  </div>
</div>
{% endblock %}
